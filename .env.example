# ═══════════════════════════════════════════════════════════
# V1 Institutional Crypto Arbitrage Scanner — Environment
# ═══════════════════════════════════════════════════════════
# Copy to .env and fill in values as needed.
# All values can also be overridden with ARBS_ prefix at runtime.

# ── Exchange API Keys (read-only, for authenticated endpoints if needed) ──
BINANCE_API_KEY=
BINANCE_SECRET=
BYBIT_API_KEY=
BYBIT_SECRET=
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=

# ── Storage ──
DB_PATH=./data/arbitrage.db
LOG_PATH=./logs/scanner.log
LOG_LEVEL=INFO

# ── Dashboard ──
DASHBOARD_PORT=8501
DASHBOARD_REFRESH_SECONDS=3

# ── Runtime Overrides (examples) ──
# ARBS_FILTERS__MIN_ANNUALIZED_BASIS=0.08
# ARBS_SYSTEM__SCAN_INTERVAL_SECONDS=2
